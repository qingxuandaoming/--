        "price": ".p-price i",
        "image": ".p-img img",
        "shop": ".p-shop a",
        "sales": ".p-commit a"
      },
      "rate_limit": {
        "requests_per_minute": 40,
        "description": "每分钟最大请求数"
      }
    },
    "tmall": {
      "enabled": false,
      "name": "天猫",
      "search_url": "https://list.tmall.com/search_product.htm?q={keyword}&sort=s&style=g",
