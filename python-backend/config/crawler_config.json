  "platforms": {
    "taobao": {
      "enabled": true,
      "name": "淘宝",
      "search_url": "https://s.taobao.com/search?q={keyword}&sort=sale-desc",
      "selectors": {
        "items": ".item",
        "title": ".title a",
        "price": ".price strong",
        "image": ".pic img",
        "shop": ".shop a",
        "sales": ".deal-cnt"
      },
      "rate_limit": {
        "requests_per_minute": 30,
        "description": "每分钟最大请求数"
      }
    },
    "jd": {
      "enabled": true,
      "name": "京东",
      "search_url": "https://search.jd.com/Search?keyword={keyword}&enc=utf-8",
