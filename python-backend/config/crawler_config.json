        "items": ".product",
        "title": ".productTitle a",
        "price": ".productPrice em",
        "image": ".productImg img",
        "shop": ".productShop a",
        "sales": ".productStatus span"
      },
      "rate_limit": {
        "requests_per_minute": 20,
