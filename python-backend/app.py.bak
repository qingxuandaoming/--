@app.route('/api/queue/cleanup', methods=['POST'])
def cleanup_completed_tasks():
    """еЁ“е‘ҜжӮҠе®ёжҸ’з•¬йҺҙж„®ж®‘жө иҜІе§ҹ"""
    try:
        data = request.get_json() or {}
        days = data.get('days', 7)
        
        cleaned_count = crawler_queue_service.clear_completed_tasks(days)
        
        return jsonify({
            'success': True,
            'data': {
                'cleaned_count': cleaned_count
            },
            'message': f'е®ёеҸүз«»йҗһ?{cleaned_count} ж¶“оҒ„еҮЎзҖ№еұҫеһҡйҗЁеӢӘжҚўйҚ”?
        })
        
    except Exception as e:
        logger.error(f"еЁ“е‘ҜжӮҠе®ёжҸ’з•¬йҺҙж„ӘжҚўйҚ”вҖігҒ‘з’җ? {str(e)}")
        return jsonify({
            'success': False,
            'message': f'еЁ“е‘ҜжӮҠжө иҜІе§ҹжҫ¶иҫ«и§Ұ: {str(e)}'
        }), 500

