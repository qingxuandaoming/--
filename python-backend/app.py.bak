@app.route('/api/equipment/crawl', methods=['POST'])
def crawl_equipment():
    """йҺөе¬Әе§©з‘ҷп№ҖеҪӮйҗ–о„ғж«•"""
    try:
        data = request.get_json()
        platform = data.get('platform', 'all')
        category = data.get('category', 'all')
        
        # еҜ®еӮӣо„һйҺөСҶо”‘йҗ–о„ғж«•жө иҜІе§ҹ
        task_id = crawler_service.start_crawl_task(platform, category)
        
        return jsonify({
            'success': True,
            'message': 'йҗ–о„ғж«•жө иҜІе§ҹе®ёжҸ’жғҺйҚ”?,
            'task_id': task_id
        })
    except Exception as e:
        logger.error(f"йҚҡоҲҡе§©йҗ–о„ғж«•жҫ¶иҫ«и§Ұ: {str(e)}")
        return jsonify({
            'success': False,
            'message': 'йҚҡоҲҡе§©йҗ–о„ғж«•жҫ¶иҫ«и§Ұ'
        }), 500

