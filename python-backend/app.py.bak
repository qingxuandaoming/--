@app.route('/api/config/crawler/keywords/<category>', methods=['POST'])
def add_category_keywords(category):
    """йҚҡжҲқеһҺз»«з»ҳеқҠйҚ”зҠІеҸ§й–ҝоҶҝзҳқ"""
    try:
        data = request.get_json()
        keywords = data.get('keywords', [])
        
        if not keywords:
            return jsonify({
                'success': False,
                'message': 'йҚҸжҠҪж•ӯз’Үе¶…еһӘзҗӣг„Өз¬үй‘іжҲ’иҙҹз»Ң?
            }), 400
        
        success = crawler_config_service.add_keywords_to_category(category, keywords)
        
        if success:
            return jsonify({
                'success': True,
                'message': f'йҺҙж„¬е§ӣеЁЈиҜІе§һ {len(keywords)} ж¶“оҒ„еҸ§й–ҝоҶҝзҳқйҚ’жқҝеһҺз»«?{category}'
            })
        else:
            return jsonify({
                'success': False,
                'message': 'еЁЈиҜІе§һйҚҸжҠҪж•ӯз’Үе¶…гҒ‘з’җ?
            }), 500
    
    except Exception as e:
        logger.error(f"еЁЈиҜІе§һйҚ’е—ҷиў«йҚҸжҠҪж•ӯз’Үе¶…гҒ‘з’җ? {str(e)}")
        return jsonify({
            'success': False,
            'message': f'еЁЈиҜІе§һйҚҸжҠҪж•ӯз’Үе¶…гҒ‘з’җ? {str(e)}'
        }), 500

@app.route('/api/config/crawler/keywords/<category>', methods=['DELETE'])
def remove_category_keywords(category):
    """жө еәЎеһҺз»«иҚӨР©й—„гӮ…еҸ§й–ҝоҶҝзҳқ"""
    try:
        data = request.get_json()
        keywords = data.get('keywords', [])
        
        if not keywords:
            return jsonify({
                'success': False,
                'message': 'йҚҸжҠҪж•ӯз’Үе¶…еһӘзҗӣг„Өз¬үй‘іжҲ’иҙҹз»Ң?
            }), 400
        
        success = crawler_config_service.remove_keywords_from_category(category, keywords)
        
        if success:
            return jsonify({
                'success': True,
                'message': f'йҺҙж„¬е§ӣжө еәЎеһҺз»«?{category} з»үе©ҡж«Һ {len(keywords)} ж¶“оҒ„еҸ§й–ҝоҶҝзҳқ'
            })
        else:
            return jsonify({
                'success': False,
                'message': 'з»үе©ҡж«ҺйҚҸжҠҪж•ӯз’Үе¶…гҒ‘з’җ?
            }), 500
    
    except Exception as e:
        logger.error(f"з»үе©ҡж«ҺйҚ’е—ҷиў«йҚҸжҠҪж•ӯз’Үе¶…гҒ‘з’җ? {str(e)}")
        return jsonify({
            'success': False,
            'message': f'з»үе©ҡж«ҺйҚҸжҠҪж•ӯз’Үе¶…гҒ‘з’җ? {str(e)}'
        }), 500

@app.route('/api/config/crawler/platform/<platform>/status', methods=['PUT'])
def update_platform_status(platform):
    """йҸҮеӯҳжҹҠйӘһеҶІеҪҙйҚҡоҲңж•ӨйҗҳиҲөвӮ¬?""
    try:
        data = request.get_json()
        enabled = data.get('enabled', False)
        
        success = crawler_config_service.update_platform_status(platform, enabled)
        
        if success:
            status = 'йҚҡоҲңж•Ө' if enabled else 'з»ӮдҪәж•Ө'
            return jsonify({
                'success': True,
                'message': f'йӘһеҶІеҪҙ {platform} е®ёзһ·status}'
            })
        else:
            return jsonify({
                'success': False,
                'message': 'йҸҮеӯҳжҹҠйӘһеҶІеҪҙйҗҳиҲөвӮ¬дҪёгҒ‘з’җ?
            }), 500
    
    except Exception as e:
        logger.error(f"йҸҮеӯҳжҹҠйӘһеҶІеҪҙйҗҳиҲөвӮ¬дҪёгҒ‘з’җ? {str(e)}")
        return jsonify({
            'success': False,
            'message': f'йҸҮеӯҳжҹҠйӘһеҶІеҪҙйҗҳиҲөвӮ¬дҪёгҒ‘з’җ? {str(e)}'
        }), 500

