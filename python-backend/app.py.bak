@app.route('/api/config/crawler', methods=['PUT'])
def update_crawler_config():
    """йҸҮеӯҳжҹҠйҗ–о„ғж«•й–°е¶Үз–Ҷ"""
    try:
        data = request.get_json()
        key_path = data.get('key')
        value = data.get('value')
        
        if not key_path:
            return jsonify({
                'success': False,
                'message': 'зјӮе“„зҡҜй–°е¶Үз–Ҷй–ҝоҶҝзҹҫеҜ°?
            }), 400
        
        success = crawler_config_service.set_config(key_path, value)
        
        if success:
            return jsonify({
                'success': True,
                'message': 'й–°е¶Үз–ҶйҸҮеӯҳжҹҠйҺҙж„¬е§ӣ'
            })
        else:
            return jsonify({
                'success': False,
                'message': 'й–°е¶Үз–ҶйҸҮеӯҳжҹҠжҫ¶иҫ«и§Ұ'
            }), 500
    
    except Exception as e:
        logger.error(f"йҸҮеӯҳжҹҠйҗ–о„ғж«•й–°е¶Үз–Ҷжҫ¶иҫ«и§Ұ: {str(e)}")
        return jsonify({
            'success': False,
            'message': f'йҸҮеӯҳжҹҠй–°е¶Үз–Ҷжҫ¶иҫ«и§Ұ: {str(e)}'
        }), 500

@app.route('/api/config/crawler/summary', methods=['GET'])
def get_crawler_config_summary():
