@app.route('/api/validation/validate', methods=['POST'])
def validate_equipment_data():
    """жҘ еІғзҳүз‘Ғе‘ӯоҳ¬йҸҒзүҲеөҒ"""
    try:
        data = request.get_json()
        equipment_data = data.get('equipment_data')
        
        if not equipment_data:
            return jsonify({
                'success': False,
                'message': 'зјӮе“„зҡҜз‘Ғе‘ӯоҳ¬йҸҒзүҲеөҒ'
            }), 400
        
        validation_result = data_validation_service.validate_equipment_data(equipment_data)
        
        return jsonify({
            'success': True,
            'data': validation_result
        })
        
    except Exception as e:
        logger.error(f"жҘ еІғзҳүз‘Ғе‘ӯоҳ¬йҸҒзүҲеөҒжҫ¶иҫ«и§Ұ: {str(e)}")
        return jsonify({
            'success': False,
            'message': f'жҘ еІғзҳүжҫ¶иҫ«и§Ұ: {str(e)}'
        }), 500

