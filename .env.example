# ============================================================
# 灵境行者 - 本地开发环境变量模板
# 复制本文件为 .env 并填入真实值
# .env 已被 Git 忽略，请勿提交到版本库
# ============================================================

# ─── 数据库配置 ──────────────────────────────────────────────
DB_PASSWORD=your_db_password_here

# ─── 高德地图 API 配置 ───────────────────────────────────────
# 申请地址: https://lbs.amap.com/
AMAP_WEB_API_KEY=your_amap_web_api_key_here
AMAP_JS_API_KEY=your_amap_js_api_key_here
AMAP_SECURITY_KEY=your_amap_security_key_here

# ─── JWT 配置 ────────────────────────────────────────────────
# 建议生成随机字符串，长度不低于 32 位
JWT_SECRET=your_jwt_secret_here

# ─── Python Flask 配置 ───────────────────────────────────────
SECRET_KEY=your_flask_secret_key_here
